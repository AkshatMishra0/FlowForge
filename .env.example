# ================================================================================
# FlowForge Environment Configuration
# ================================================================================
# This file contains all environment variables needed for the FlowForge application
# Copy this file to .env and update with your actual values
# Last updated: February 2026
# ================================================================================

# ================================================================================
# Application Settings
# ================================================================================
NODE_ENV="development"  # development | production | test
LOG_LEVEL="debug"       # error | warn | info | debug
PORT=4000               # Main API port

# ================================================================================
# Database Configuration
# ================================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/flowforge?schema=public"

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=30000

# ================================================================================
# Redis Configuration
# ================================================================================
# Redis connection URL for caching and sessions
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# Cache TTL settings (in seconds)
CACHE_TTL_SHORT=300      # 5 minutes
CACHE_TTL_MEDIUM=1800    # 30 minutes
CACHE_TTL_LONG=3600      # 1 hour

# ================================================================================
# Authentication & Security
# ================================================================================
# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-token-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-change-in-production"

# Rate Limiting
RATE_LIMIT_WINDOW=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BLOCK_DURATION=3600000  # 1 hour in milliseconds

# ================================================================================
# OAuth Providers
# ================================================================================
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# ================================================================================
# WhatsApp Cloud API
# ================================================================================
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-verify-token"
WHATSAPP_API_VERSION="v18.0"
WHATSAPP_PHONE_ID=""
WHATSAPP_TOKEN=""

# ================================================================================
# Payment Gateway (Razorpay)
# ================================================================================
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ================================================================================
# Google Calendar Integration
# ================================================================================
GOOGLE_CALENDAR_CLIENT_ID="your-calendar-client-id"
GOOGLE_CALENDAR_CLIENT_SECRET="your-calendar-client-secret"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/auth/google/calendar"

# ================================================================================
# Email Service
# ================================================================================
# Choose provider: sendgrid | ses | smtp
EMAIL_PROVIDER="smtp"

# SendGrid Configuration
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@flowforge.com"
SENDGRID_FROM_NAME="FlowForge"

# AWS SES Configuration
AWS_SES_REGION="us-east-1"
AWS_SES_ACCESS_KEY_ID="your-aws-access-key"
AWS_SES_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_SES_FROM_EMAIL="noreply@flowforge.com"

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@flowforge.com"
SMTP_FROM_NAME="FlowForge"

# ================================================================================
# Application URLs
# ================================================================================
BACKEND_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
WORKER_URL="http://localhost:4001"

# ================================================================================
# File Upload & Storage
# ================================================================================
# Storage provider: local | s3 | cloudinary
STORAGE_PROVIDER="local"

# Local storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760  # 10MB in bytes

# S3 Configuration
S3_BUCKET_NAME="flowforge-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-s3-access-key"
S3_SECRET_ACCESS_KEY="your-s3-secret-key"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ================================================================================
# Monitoring & Logging
# ================================================================================
# Sentry Error Tracking
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENVIRONMENT="development"

# Analytics
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# ================================================================================
# Background Jobs (BullMQ)
# ================================================================================
BULL_QUEUE_PREFIX="flowforge:"
BULL_MAX_RETRIES=3
BULL_BACKOFF_DELAY=5000

# ================================================================================
# Feature Flags
# ================================================================================
ENABLE_AI_FEATURES=false
ENABLE_WHATSAPP_AUTOMATION=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true

# ================================================================================
# Development Tools
# ================================================================================
# Swagger API Documentation
ENABLE_SWAGGER=true
SWAGGER_PATH="/api/docs"

# Debug Mode
DEBUG=false
VERBOSE_LOGGING=false

# Hot Reload
HOT_RELOAD=true

# ================================================================================
# Testing
# ================================================================================
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/flowforge_test?schema=public"
TEST_REDIS_URL="redis://localhost:6379/1"

# ================================================================================
# Production Optimizations
# ================================================================================
# CORS Settings
CORS_ORIGIN="http://localhost:3000,http://localhost:4000"
CORS_CREDENTIALS=true

# Compression
ENABLE_COMPRESSION=true

# Health Check
HEALTH_CHECK_PATH="/health"
HEALTH_CHECK_DETAILED_PATH="/health/detailed"

# ================================================================================
# Optional Third-Party Integrations
# ================================================================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Slack (Notifications)
SLACK_WEBHOOK_URL=""
SLACK_BOT_TOKEN=""

# Stripe (Alternative Payment)
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
